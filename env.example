# ============================================
# PLANTILLA DE CONFIGURACIÓN - PythonAnywhere
# ============================================
# Copia este archivo como .env y completa los valores
# NUNCA subas el archivo .env con credenciales reales a GitHub

# ============================================
# CONFIGURACIÓN DE BASE DE DATOS
# ============================================
DB_TYPE=mysql
MYSQL_HOST=tu_usuario.mysql.pythonanywhere-services.com
MYSQL_PORT=3306
MYSQL_DATABASE=tu_usuario$nombre_base_datos
MYSQL_USER=tu_usuario
MYSQL_PASSWORD=tu_password_mysql
MYSQL_CHARSET=utf8mb4
MYSQL_POOL_SIZE=5

# ============================================
# CONFIGURACIÓN DE LA APLICACIÓN
# ============================================
FLASK_ENV=production
SECRET_KEY=genera_una_clave_secreta_aqui_con_al_menos_32_caracteres
PORT=5000
TZ=America/Lima

# ============================================
# CONFIGURACIÓN DE CORREO ELECTRÓNICO
# ============================================
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=tu_correo@gmail.com
MAIL_PASSWORD=tu_app_password
MAIL_DEFAULT_SENDER=tu_correo@gmail.com

# ============================================
# INSTRUCCIONES PARA OBTENER APP PASSWORD DE GMAIL
# ============================================
# 1. Ve a https://myaccount.google.com/security
# 2. Activa la verificación en dos pasos si no está activa
# 3. Ve a "Contraseñas de aplicaciones" (App passwords)
# 4. Selecciona "Correo" y "Equipo con Windows"
# 5. Copia la contraseña de 16 caracteres generada
# 6. Usa esa contraseña como MAIL_PASSWORD
